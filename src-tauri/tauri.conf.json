{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "uSTAT",
  "version": "0.1.0",
  "identifier": "com.ustat.app",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "./splash"
  },
  "app": {
    "windows": [
      {
        "title": "uSTAT — Statistical Analysis",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.plot.ly; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/afstudy20-gif/ustat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW51c2VkX3BsYWNlaG9sZGVyX2Zvcl90YXVyaV91cGRhdGVyX2tleQ=="
    },
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "ustat-backend",
          "cmd": "",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
